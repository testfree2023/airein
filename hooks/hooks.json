{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/test-guard.js\"",
            "timeout": 5
          }
        ],
        "description": "Test guard: block source file creation/edit when no corresponding test exists (Iron Rule 1)"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-edit-impact.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Impact analysis: check how many files import the target before editing"
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/plan-gate.js\"",
            "timeout": 5
          }
        ],
        "description": "Plan gate: block source edits without approved plan"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/approval-sequence.js\"",
            "timeout": 5
          }
        ],
        "description": "Approval sequence: enforce R→D→T creation order"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/approval-guard.js\"",
            "timeout": 5
          }
        ],
        "description": "Approval guard: protect approval state in progress.md from unauthorized changes"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/tests-ledger-gate.js\"",
            "timeout": 5
          }
        ],
        "description": "Tests ledger gate: block implement task completion without tests.md pass row"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/roadmap-gate.js\"",
            "timeout": 5
          }
        ],
        "description": "Roadmap gate: validate docs/roadmap.md active-section contract"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/progress-completion-gate.js\"",
            "timeout": 5
          }
        ],
        "description": "Progress completion gate: progress.md completion claims require tasks.md Status=completed"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/doc-file-warning.js\"",
            "timeout": 5
          }
        ],
        "description": "Doc file warning: warn about non-standard documentation files (PreToolUse, visible to model)"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-commit-gate.js\"",
            "timeout": 125
          }
        ],
        "description": "Commit gate: verify build + tests pass, check test coverage before git commit"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-compact.js\""
          }
        ],
        "description": "Context preservation: extract key info before compaction (~800 tokens)"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start.js\""
          }
        ],
        "description": "Load minimal context on new session (~200 tokens)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/quality-sentinel.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Quality sentinel: check for debug statements, secrets, TODOs after code edits"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:quality-gate\" \"scripts/hooks/quality-gate.js\" \"standard,strict\"",
            "async": true,
            "timeout": 30
          }
        ],
        "description": "Run quality gate checks after file edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:edit:format\" \"scripts/hooks/post-edit-format.js\" \"standard,strict\""
          }
        ],
        "description": "Auto-format JS/TS files after edits (auto-detects Biome or Prettier)"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags.js\" \"post:edit:typecheck\" \"scripts/hooks/post-edit-typecheck.js\" \"standard,strict\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/contract-sentinel.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Contract sentinel: detect exported API signature changes and warn"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/progress-sync.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Progress sync: auto-update progress.md when tasks.md changes"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/archive-trigger.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Archive trigger: nudge model to run /archive-plan when a plan's progress.md reaches completion (non-blocking, per-plan dedup)"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/structure-sync.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Structure sync: update token estimates in structure.md after source edits"
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/read-dedup.js\"",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Read dedup: warn when same file read multiple times in a session"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stop-test-gate.js\"",
            "async": true,
            "timeout": 125
          }
        ],
        "description": "Stop hooks: test gate + regression check + session state persist (chained)"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/self-learning-prompt.js\"",
            "timeout": 5
          }
        ],
        "description": "Self-learning: inject LLM hitchhiking meta-prompt so the model recognizes persistent allow/deny instructions and writes the pending buffer (Stop hook archives + promotes; never touches memory)"
      }
    ]
  }
}
