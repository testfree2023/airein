# Normalize text files to LF for cross-platform consistency.
# Context: Windows devs with core.autocrlf=true get CRLF working trees; tarring
# or syncing those to macOS/Linux ships CRLF shebangs (`#!/usr/bin/env bash\r`),
# which the kernel can't exec → silent fallback to sh → `set -euo pipefail`
# fails (Bug 2026-07-10 dual-machine reinstall). Pinning eol=lf at the repo
# root prevents this for every clone, regardless of the user's autocrlf setting.
* text=auto eol=lf

# Scripts & docs — LF is mandatory (CRLF shebang is fatal on Unix)
*.sh   text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.mdc  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows-only scripts keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary — never normalize
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gz   binary
*.tgz  binary
*.tar  binary
