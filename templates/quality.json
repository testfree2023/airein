{
  "testCoverage": {
    "minRatio": 0.3,
    "minSourceFiles": 2,
    "functionThreshold": 3
  },
  "blocking": {
    "testFailure": true,
    "lowCoverage": true,
    "buildFailure": true,
    "untestedSource": true
  },
  "pipelineRoles": {
    "enabled": true
  },
  "flowControl": {
    "perTaskReview": false,
    "worktreeIsolation": false
  },
  "testGuard": {
    "enabled": true,
    "mode": "strict"
  },
  "testsLedger": {
    "enabled": false,
    "mode": "strict"
  },
  "roadmapGate": {
    "enabled": true,
    "mode": "advisory"
  },
  "approvalGuard": {
    "mode": "console-confirm"
  },
  "planGate": {
    "mode": "advisory",
    "exemptPaths": [
      "docs/",
      ".claude/",
      "scripts/hooks/",
      "test/"
    ],
    "requireActiveTask": true
  },
  "taskPickup": {
    "onBlocked": "wait_user"
  },
  "planWorkflow": {
    "enforceGrilling": true,
    "pipeline": "auto"
  },
  "languageProfiles": {
    "active": []
  },
  "aireinLog": {
    "enabled": true,
    "level": "info",
    "retentionDays": 7,
    "slowHookMs": 2000
  },
  "progressCompletionGate": {
    "enabled": true,
    "mode": "strict"
  },
  "progressApprovalGate": {
    "enabled": true,
    "mode": "strict"
  }
}
