#!/usr/bin/env bash
# airein — unified install orchestrator (P004)
# Usage: airein setup|update|uninstall [options]
#        airein              # 打印用法与示例

set -euo pipefail

AIREIN_HOME="${AIREIN_HOME:-$HOME/.airein}"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
INVOKE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve runnable tree: prefer ~/.airein kernel, else script's directory (dev checkout).
if [[ -f "$AIREIN_HOME/scripts/lib/install-orchestrator.js" ]]; then
  ROOT="$AIREIN_HOME"
elif [[ -f "$INVOKE_DIR/scripts/lib/install-orchestrator.js" ]]; then
  ROOT="$INVOKE_DIR"
else
  echo "❌ airein kernel not found. Run from airein repo or install to ~/.airein first." >&2
  exit 1
fi

# When invoked from a checkout (not from ~/.airein), remember it so `update` can use
# that tree as source even though the orchestrator binary runs from the installed kernel.
if [[ -f "$INVOKE_DIR/VERSION" && -f "$INVOKE_DIR/scripts/lib/install-orchestrator.js" \
      && "$(cd "$INVOKE_DIR" && pwd)" != "$(cd "$AIREIN_HOME" 2>/dev/null && pwd || true)" ]]; then
  export AIREIN_INVOKE_SOURCE="$INVOKE_DIR"
fi

HELPERS="$ROOT/scripts/lib/install-helpers.sh"
if [[ -f "$HELPERS" ]]; then
  # shellcheck source=scripts/lib/install-helpers.sh
  . "$HELPERS"
  NODE_BIN="$(resolve_node_bin)"
else
  NODE_BIN="$(command -v node 2>/dev/null || true)"
fi

if [[ -z "$NODE_BIN" ]]; then
  echo "❌ Node.js required" >&2
  exit 1
fi

export AIREIN_SCRIPT_DIR="$ROOT"
# Prefer checkout orchestrator when invoked as ./airein from a source tree —
# otherwise `update` keeps running the *pre-sync* in-memory kernel code and
# dashboard refresh / new maintenance logic never runs in that process.
ORCH_ROOT="$ROOT"
if [[ -n "${AIREIN_INVOKE_SOURCE:-}" \
   && -f "$AIREIN_INVOKE_SOURCE/scripts/lib/install-orchestrator.js" ]]; then
  ORCH_ROOT="$AIREIN_INVOKE_SOURCE"
fi
exec "$NODE_BIN" "$ORCH_ROOT/scripts/lib/install-orchestrator.js" "$@"
